RAILPACK_JDK_VERSION=25

# Port provided by the hosting platform. Keep 8080 for local runs.
PORT=8080

# MySQL connection used by Spring Boot.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=PuntoDeVentaDB
DB_USER=root
DB_PASSWORD=change_me

# Comma-separated frontend origins allowed by CORS.
# Local example:
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production example:
# APP_CORS_ALLOWED_ORIGINS=https://tu-frontend.vercel.app
